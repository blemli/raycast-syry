{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "raycast-syry",
  "title": "Syry",
  "description": "Call phone numbers via the syry CLI (Yealink T31P).",
  "icon": "icon.png",
  "author": "blemli",
  "license": "MIT",
  "categories": ["Productivity"],
  "commands": [
    {
      "name": "call",
      "title": "Call Number",
      "description": "Place a call to a phone number using syry.",
      "mode": "no-view",
      "arguments": [
        {
          "name": "number",
          "type": "text",
          "placeholder": "+41 79 123 45 67",
          "required": true
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.80.0",
    "@raycast/utils": "^1.17.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "20.8.10",
    "@types/react": "18.3.3",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
